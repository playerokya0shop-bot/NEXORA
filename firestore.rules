rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: username
    // Fields:
    //   - username: string (required)
    //   - password: string (required) - hashed
    //   - role: string (required) - 'admin' or 'user'
    //   - createdAt: string (required)
    //
    // Collection: messages
    // Document ID: auto-generated
    // Fields:
    //   - sender: string (required)
    //   - text: string (required)
    //   - timestamp: string (required)
    //   - file: map (optional)
    //
    // Collection: adminFiles
    // Document ID: auto-generated
    // Fields:
    //   - name: string (required)
    //   - url: string (required)
    //   - uploadedAt: string (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      // In this app, admin is identified by username 'k1ros'
      // Since we use custom auth in Express, we can't easily check request.auth.uid for 'k1ros'
      // unless we use Firebase Auth. 
      // For now, these rules are a prototype.
      return true; // Temporary for development, will harden later
    }

    match /users/{username} {
      allow read, write: if true; // Backend handles auth for now
    }

    match /messages/{messageId} {
      allow read, write: if true; // Backend handles auth for now
    }

    match /adminFiles/{fileId} {
      allow read, write: if true; // Backend handles auth for now
    }
  }
}
