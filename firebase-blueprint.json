{
  "entities": {
    "ChatMetadata": {
      "title": "ChatMetadata",
      "description": "Metadata for a specific chat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "password": { "type": "string", "description": "Hashed password for the chat" }
      },
      "required": ["chatId", "password"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "username": {
          "type": "string",
          "description": "Unique username"
        },
        "role": {
          "type": "string",
          "enum": ["admin", "moderator", "user"],
          "description": "User role"
        },
        "banned": {
          "type": "boolean",
          "description": "Whether the user is banned"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["username"]
    },
    "Application": {
      "title": "Application",
      "description": "Moderator application",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "reason", "status", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique message ID"
        },
        "sender": {
          "type": "string",
          "description": "Username of the sender"
        },
        "text": {
          "type": "string",
          "description": "Message content"
        },
        "timestamp": {
          "type": "number",
          "description": "When the message was sent (milliseconds)"
        },
        "type": {
          "type": "string",
          "enum": ["text", "poll", "file"],
          "description": "Type of message"
        },
        "isSystem": {
          "type": "boolean",
          "description": "Whether it's a system message"
        },
        "file": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "url": { "type": "string" },
            "type": { "type": "string" }
          },
          "description": "Optional attached file"
        },
        "poll": {
          "type": "object",
          "properties": {
            "question": { "type": "string" },
            "options": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "text": { "type": "string" },
                  "votes": { "type": "array", "items": { "type": "string" } }
                }
              }
            }
          }
        },
        "reactions": {
          "type": "object",
          "description": "Emoji reactions to the message (keys are emojis, values are arrays of usernames)"
        }
      },
      "required": ["sender", "text", "timestamp"]
    },
    "AdminFile": {
      "title": "AdminFile",
      "description": "Metadata for files uploaded by admin",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "url": { "type": "string" },
        "type": { "type": "string" },
        "size": { "type": "number" },
        "uploadedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "url", "uploadedAt"]
    },
    "SystemSettings": {
      "title": "SystemSettings",
      "description": "Global system settings",
      "type": "object",
      "properties": {
        "welcomeMessage": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "chatEnabled": { "type": "boolean" },
        "registrationEnabled": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Global chat messages"
    },
    "/adminFiles/{fileId}": {
      "schema": "AdminFile",
      "description": "Files uploaded by admin"
    },
    "/applications/{applicationId}": {
      "schema": "Application",
      "description": "Moderator applications"
    },
    "/chatMetadata/{chatId}": {
      "schema": "ChatMetadata",
      "description": "Metadata for chats, including passwords"
    },
    "/system/{documentId}": {
      "schema": "SystemSettings",
      "description": "Global system configuration"
    }
  }
}
